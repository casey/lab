#!/usr/bin/env python3

import json
import glob
import os
import sys
from datetime import datetime

sessions = []

for jsonl in glob.glob("/root/.claude/projects/*/*.jsonl"):
    session_id = os.path.basename(jsonl).replace(".jsonl", "")
    mtime = os.path.getmtime(jsonl)

    cwd = None
    branch = None
    with open(jsonl) as f:
        for line in f:
            obj = json.loads(line)
            if obj.get("type") == "user":
                cwd = obj.get("cwd", "")
                branch = obj.get("gitBranch") or ""
                if branch == "HEAD":
                    branch = ""
                break

    if cwd is None:
        continue

    sessions.append((mtime, session_id, cwd, branch))

sessions.sort(key=lambda s: s[0], reverse=True)

limit = int(sys.argv[1]) if len(sys.argv) > 1 else 20

for mtime, session_id, cwd, branch in sessions[:limit]:
    date = datetime.fromtimestamp(mtime).strftime("%Y-%m-%d")
    time = datetime.fromtimestamp(mtime).strftime("%H:%M")
    fields = [session_id, date, time, cwd]
    if branch:
        fields.append(branch)
    print("  ".join(fields))
